{
  "name": "stellargrant-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "typeorm:sync": "tsx src/scripts/sync-db.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/db/typeorm.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/db/typeorm.config.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/db/typeorm.config.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/db/typeorm.config.ts"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@stellar/stellar-sdk": "^13.3.0",
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "json2csv": "^6.0.0-alpha.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "pdfmake": "^0.3.7",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "typeform": "^1.0.1",
    "typeorm": "^0.3.24",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^4.17.21",
    "@types/json2csv": "^5.0.7",
    "@types/node": "^22.13.10",
    "@types/pdfmake": "^0.3.2",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "sql.js": "^1.14.1",
    "supertest": "^7.1.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.8"
  }
}
